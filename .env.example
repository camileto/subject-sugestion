OPENAI_API_KEY=your_api_key_here
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
SIMILARITY_THRESHOLD=0.92
MIN_PERSONAL_SAMPLE_SIZE=3

# Optional: only needed if you pass "country" in the request to get
# seasonal/occasion-aware subject lines (Christmas, Black Friday, etc).
CALENDARIFIC_API_KEY=your_calendarific_api_key_here
OCCASION_LOOKAHEAD_DAYS=30
OCCASION_CACHE_TTL_SECONDS=86400
